# =============================================================================
# Smart Apply Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- App ---
APP_ENV=local
LOG_LEVEL=INFO

# --- LLM ---
# Provider: mock | qwen | deepseek | openai
LLM_PROVIDER=mock
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

# --- Embedding ---
# Provider: mock | hash | qwen | openai
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=16

# --- Vector Store ---
VECTOR_STORE_BACKEND=memory
VECTOR_STORE_PATH=data/vector_store
CHROMA_PERSIST_DIR=data/chroma

# --- RAG ---
CHUNK_SIZE=800
CHUNK_OVERLAP=100
RETRIEVAL_TOP_K=8
RERANK_TOP_K=5
MIN_RETRIEVAL_SCORE=0.65
MAX_RETRIES=2

# --- Hybrid Retrieval Weights ---
HYBRID_VECTOR_WEIGHT=0.40
HYBRID_KEYWORD_WEIGHT=0.35
HYBRID_METADATA_WEIGHT=0.15
HYBRID_PRIORITY_WEIGHT=0.10

# --- Output ---
OUTPUT_DIR=outputs
RAG_REPORT_DIR=outputs/rag_reports
DIAGNOSTICS_DIR=outputs/diagnostics
TRACE_DIR=outputs/traces

# --- UI / API ---
STREAMLIT_PORT=8501
FASTAPI_PORT=8000
